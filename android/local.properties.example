# Rename this file to "local.properties" and update the SDK path below.
# Do NOT commit local.properties — it contains machine-specific paths.

sdk.dir=C\:\\Users\\<you>\\AppData\\Local\\Android\\Sdk
# sdk.dir=/Users/<you>/Library/Android/sdk

# Optional: override Gradle JDK (must be 17+). If unset, see gradle.properties.
# jdk.dir=C\:\\Program Files\\Android\\Android Studio\\jbr
