{
  "name": "fitsense-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FitSense AI API — handoff relay and cloud sync",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/handoff.test.ts test/handoffSession.test.ts test/validation.test.ts test/sessionAuth.test.ts",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=22.16.0 <23",
    "npm": ">=11.6.0 <12"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@11.6.0",
  "overrides": {
    "uuid": "11.1.1"
  }
}
