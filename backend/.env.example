# Server
PORT=8787
NODE_ENV=development

# Comma-separated allowed origins (use * only in local dev)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Handoff session TTL (milliseconds)
HANDOFF_TTL_MS=300000

# Database (Neon/Postgres). When DATABASE_URL is set, sync and handoff default
# to Postgres unless explicitly overridden.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Cloud sync store: firestore or postgres.
# SYNC_STORE=postgres

# Production handoff store: postgres or upstash. Use memory only for local dev.
# HANDOFF_STORE=postgres
# HANDOFF_STORE=upstash
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Request limits
JSON_LIMIT=64kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_HANDOFF_READ_MAX=60
RATE_LIMIT_HANDOFF_WRITE_MAX=20
RATE_LIMIT_SYNC_MAX=120

# Firebase Admin - required for production /v1/sync auth, even when sync data
# is stored in Postgres. The frontend sends Firebase anonymous-auth ID tokens.
# Option A: path to service account JSON (from Firebase console)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Option B: inline JSON (single line) - useful for containers
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Dev only: skip Firebase token verification and use header uid
# SKIP_AUTH=true
