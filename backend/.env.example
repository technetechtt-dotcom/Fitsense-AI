# Server
PORT=8787
NODE_ENV=development

# Comma-separated allowed origins (use * only in local dev)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Handoff session TTL (milliseconds)
HANDOFF_TTL_MS=300000

# Firebase Admin — required for /v1/sync routes
# Option A: path to service account JSON (from Firebase console)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Option B: inline JSON (single line) — useful for containers
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Dev only: skip Firebase token verification and use header uid
# SKIP_AUTH=true
