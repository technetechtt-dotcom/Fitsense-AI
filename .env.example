# Firebase Web SDK config — copy to `.env.local` and fill in the values
# from your Firebase project console (Project settings → Web app).
#
# All values are public by design (they identify the project, not auth
# secrets). Real auth happens via the security rules + anonymous auth.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# Enable Google as a sign-in provider in Firebase Authentication so a guest can
# link the same Fit ID for cross-device restore.

# Optional — leave blank to use defaults.
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# FitSense API (backend/) — handoff + cloud sync proxy
#   npm run dev:full   (web + API)  OR  npm run dev:api in backend/
#
# Dev (Vite proxies /v1 and /health to :8787):
VITE_API_BASE_URL=
#
# Or direct URL (CORS must allow localhost:5173 in backend/.env):
# VITE_API_BASE_URL=http://localhost:8787
#
# Local sync without Firebase tokens (backend SKIP_AUTH=true only):
# VITE_API_DEBUG_UID=dev-user-1

# Demo-only simulated scan fallback. Leave false/blank in production so users
# are forced onto real AR, A4, or bank-card measurement paths.
# VITE_ENABLE_DEMO_SCAN=false

# Production privacy policy display.
VITE_PRIVACY_CONTROLLER_NAME=FitSense AI
# VITE_PRIVACY_CONTACT_URL=https://www.example.com/privacy-contact
