{
  "name": "fitsense-ai-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FitSense AI — web companion / interactive prototype.",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n web,api -c blue,green \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc -b && vite build",
    "build:sdk": "vite build --config vite.embed.config.ts",
    "build:all": "npm run build && npm run build:sdk",
    "preview": "vite preview --port 5173",
    "dev:api": "npm run dev --prefix backend",
    "handoff:relay": "npm run dev --prefix backend",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@types/qrcode": "^1.5.6",
    "firebase": "^12.13.0",
    "framer-motion": "^11.5.4",
    "lucide-react": "0.522.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "concurrently": "^9.1.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.2.0"
  }
}
