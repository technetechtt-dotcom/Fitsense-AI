{
  "name": "fitsense-ai-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FitSense AI — web companion / interactive prototype.",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n web,api -c blue,green \"npm run dev\" \"npm run dev:api\"",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "build": "npm run typecheck && vite build",
    "build:sdk": "vite build --config vite.embed.config.ts",
    "build:all": "npm run build && npm run build:sdk",
    "preview": "vite preview --port 5173",
    "dev:api": "npm run dev --prefix backend",
    "handoff:relay": "npm run dev --prefix backend",
    "lint": "eslint .",
    "test:web": "vitest run",
    "test:api": "npm run test --prefix backend",
    "test": "npm run test:web && npm run test:api",
    "check": "npm run format:check && npm run typecheck && npm run lint && npm run test && npm run build:all",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@mediapipe/tasks-vision": "^0.10.35",
    "framer-motion": "^11.5.4",
    "lucide-react": "0.522.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "latest",
    "concurrently": "^9.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "latest",
    "prettier": "^3.9.6",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.16.0 <23",
    "npm": ">=11.6.0 <12"
  },
  "packageManager": "npm@11.6.0"
}
